#
# AW869XX Driver
#

config AW869XX_HAPTIC
	tristate "Awinic AW869XX haptic driver"
	depends on I2C && INPUT_AWINIC_HAPTIC
	help
	  Say Y here if you have Awinic AW869XX haptic controller
	  chip in your system.

	  If unsure, say N.

	  To compile this driver as a module, choose M here: the
	  module will be called aw869xx.
